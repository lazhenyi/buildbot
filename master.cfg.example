# Buildbot Dispatcher Configuration
#
# Copy this file to master.cfg and customize for your environment.

master:
  name: "buildbot-dispatcher"
  web_url: "http://localhost:8010"
  # Strict Python dependency validation in CI scripts
  strict_python_deps: false
  # Directory for cloned repositories
  dispatcher_workdir: "/app/repos"
  # Runner heartbeat timeout (seconds)
  runner_timeout_secs: 300

database:
  url: "sqlite:///app/data/buildbot.db"

www:
  port: 9990
  web_port: 8010
